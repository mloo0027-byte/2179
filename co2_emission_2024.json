{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  
  "width": "container",
  "height": "container",
  

  "autosize": {
    "type": "fit",
    "contains": "padding"
  },

  "data": {
    "url": "co2_emission_2024.csv"
  },

  "encoding": {
    "y": {
      "field": "country", 
      "type": "nominal", 
      "sort": "-x", 
      "title": "Country"
    },
    "x": {
      "field": "CO2_emission", 
      "type": "quantitative", 
      "title": "CO2 Emissions (Million Tonnes)"
    }
  },
  "layer": [
    {
      "mark": "bar",
      "encoding": {
        "color": {
          "field": "CO2_emission",
          "type": "quantitative",
          "scale": {"scheme": "reds"},
          "title": "Emission Intensity",
          "legend": {
            "orient": "bottom",
            "direction": "horizontal"
          }
        }
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "xOffset": 5,
        "aria": false
      },
      "encoding": {
        "text": {"field": "CO2_emission", "type": "quantitative", "format": ".1f"},
        "color": {"value": "black"}
      }
    }
  ]
}