{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 1000,
  "height": 1000,
  "background": "#a5c9eb",
  
  "params": [
    {
      "name": "zoom_level",
      "value": 4000,
      "bind": {
        "input": "range",
        "min": 1000,
        "max": 30000,
        "step": 500,
        "name": "Zoom Scale: "
      }
    },
    {
      "name": "map_center",
      "value": [104.5, 4.1],
      "bind": {
        "input": "select",
        "options": [
          [104.5, 4.1],
          [101.69, 3.14],
          [100.33, 5.41],
          [110.36, 1.55],
          [116.07, 5.98]
        ],
        "labels": [
          "Whole Malaysia", 
          "Kuala Lumpur / Klang Valley", 
          "Penang", 
          "Kuching (Sarawak)", 
          "Kota Kinabalu (Sabah)"
        ],
        "name": "Center Focus: "
      }
    }
  ],

  "projection": {
    "type": "mercator",
    "center": {"expr": "map_center"},
    "scale": {"expr": "zoom_level"}
  },
  
  "view": {"stroke": "transparent"},
  "layer": [
    {
      "name": "Graticules",
      "data": {"graticule": {"step": [1, 1]}},
      "mark": {
        "type": "geoshape",
        "stroke": "#e0e0e0",
        "strokeWidth": 0.5
      }
    },
    {
      "name": "Background_Map",
      "data": {
        "url": "malaysia_map.topojson",
        "format": {"type": "topojson", "feature": "malaysia_state"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f9f9f9",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "tooltip": [
          {"field": "properties.name", "type": "nominal", "title": "State"}
        ]
      }
    },
    {
      "name": "Kelana_Jaya_Line",
      "data": {
        "url": "LRT_Kelana_Jaya_Linestring.csv",
        "format": {"type": "csv", "parse": {"ID": "number"}}
      },
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "color": "#ef4135"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "tooltip": {"value": "Kelana Jaya Line"}
      }
    },
    {
      "name": "Ampang_Line",
      "data": {
        "url": "LRT_Ampang_Linestring.csv",
        "format": {
          "type": "csv",
          "parse": {
            "ID": "number",
            "Longitude": "number",
            "Latitude": "number"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"} 
      ],
      "mark": {
        "type": "line", 
        "strokeWidth": 4, 
        "color": "#ffb81c"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "tooltip": {"value": "Ampang Line"}
      }
    },
    {
      "name": "Sri_Petaling_Line",
      "data": {
        "url": "LRT_SriPetaling_Linestring.csv",
        "format": {
          "type": "csv",
          "parse": {
            "ID": "number",
            "Longitude": "number",
            "Latitude": "number"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"} 
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "color": "#65318e" 
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "tooltip": {"value": "Sri Petaling Line"}
      }
    },
    {
      "name": "KTM_Intercity",
      "data": {
        "url": "KTM_Intercity_Stations_Coordinates.csv",
        "format": {
          "type": "csv",
          "parse": {
            "Longitude": "number",
            "Latitude": "number",
            "ID": "number",
            "Line": "string"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"}
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "color": "#003366"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "detail": {"field": "Line", "type": "nominal"},
        "tooltip": [
          {"field": "Line", "type": "nominal", "title": "KTM Intercity Line"}
        ]
      }
    },
    {
      "name": "ktm_komuter",
      "data": {
        "url": "ktm_komuter_stations.csv",
        "format": {
          "type": "csv",
          "parse": {
            "Longitude": "number",
            "Latitude": "number",
            "ID": "number"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"}
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "interpolate": "linear"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "color": {
          "field": "Line",
          "type": "nominal",
          "scale": {"range": ["#c44ce8", "#1f77b4", "#ff7f0e", "#2ca02c"]}
        },
        "order": {"field": "ID", "type": "quantitative"},
        "detail": {"field": "Line"},
        "tooltip": [
          {"field": "Line", "type": "nominal", "title": "KTM Komuter Line"}
        ]
      }
    }
  ]
}