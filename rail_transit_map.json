{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": 900,
  "height": 500,
  "background": "#d9e8f5",
  "autosize": {
    "type": "fit",
    "contains": "padding"
  },
  "params": [
    {
      "name": "zoom_level",
      "value": 4000,
      "bind": {
        "input": "range",
        "min": 1000,
        "max": 30000,
        "step": 500,
        "name": "Zoom Scale: "
      }
    },
    {
      "name": "map_center",
      "value": [104.5, 4.1],
      "bind": {
        "input": "select",
        "options": [
          [104.5, 4.1],
          [101.69, 3.14],
          [100.33, 5.41]
        ],
        "labels": [
          "South China Sea", 
          "Kuala Lumpur / Klang Valley", 
          "North Peninsular"
        ],
        "name": "Center Zoom: "
      }
    }
  ],
  "projection": {
    "type": "mercator",
    "center": {"expr": "map_center"},
    "scale": {"expr": "zoom_level"}
  },
  "view": {"stroke": "transparent"},
  "layer": [
    {
      "name": "Graticules",
      "data": {"graticule": {"step": [1, 1]}},
      "mark": {
        "type": "geoshape",
        "stroke": "#e0e0e0",
        "strokeWidth": 0.5
      }
    },
    {
      "name": "Background_Map",
      "data": {
        "url": "malaysia_map.topojson",
        "format": {"type": "topojson", "feature": "malaysia_state"}
      },
      "mark": {
        "type": "geoshape",
        "fill": "#f9f9f9",
        "stroke": "white",
        "strokeWidth": 1.5
      },
      "encoding": {
        "tooltip": [
          {"field": "properties.name", "type": "nominal", "title": "State"}
        ]
      }
    },
    {
      "name": "Sea_Label",
      "data": {
        "values": [
          {"Longitude": 107.5, "Latitude": 4.5, "Label": "South China Sea"}
        ]
      },
      "mark": {
        "type": "text",
        "font": "sans-serif",
        "fontSize": 14,
        "fontStyle": "italic",
        "fontWeight": "bold",
        "fill": "#5a7a9e",
        "align": "center"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "text": {"field": "Label", "type": "nominal"}
      }
    },
    {
      "name": "Kelana_Jaya_Line",
      "data": {
        "url": "LRT_Kelana_Jaya_Linestring.csv",
        "format": {"type": "csv", "parse": {"ID": "number"}}
      },
      "mark": {
        "type": "line",
        "strokeWidth": 3
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "color": {
          "datum": "Kelana Jaya Line",
          "scale": {
            "domain": [
              "Kelana Jaya Line", 
              "Ampang Line", 
              "Sri Petaling Line", 
              "KTM Intercity Line",
              "Batu Caves - Tampin",
              "Butterworth - Ipoh",
              "Butterworth - Pdg Besar",
              "Tg Malim - Pel Klang"
            ],
            "range": [
              "#d55e00",
              "#ffb81c",
              "#65318e",
              "#003366",
              "#cc79a7",
              "#56b4e9",
              "#e69f00",
              "#009e73"
            ]
          },
          "legend": {
            "title": "Malaysia Transit Networks",
            "columns": 2,
            "orient": "right"
          }
        },
        "tooltip": {"value": "Kelana Jaya Line"}
      }
    },
    {
      "name": "Ampang_Line",
      "data": {
        "url": "LRT_Ampang_Linestring.csv",
        "format": {
          "type": "csv",
          "parse": {
            "ID": "number",
            "Longitude": "number",
            "Latitude": "number"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"} 
      ],
      "mark": {
        "type": "line", 
        "strokeWidth": 4
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "color": {"datum": "Ampang Line"},
        "tooltip": {"value": "Ampang Line"}
      }
    },
    {
      "name": "Sri_Petaling_Line",
      "data": {
        "url": "LRT_SriPetaling_Linestring.csv",
        "format": {
          "type": "csv",
          "parse": {
            "ID": "number",
            "Longitude": "number",
            "Latitude": "number"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"} 
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "color": {"datum": "Sri Petaling Line"},
        "tooltip": {"value": "Sri Petaling Line"}
      }
    },
    {
      "name": "KTM_Intercity",
      "data": {
        "url": "KTM_Intercity_Stations_Coordinates.csv",
        "format": {
          "type": "csv",
          "parse": {
            "Longitude": "number",
            "Latitude": "number",
            "ID": "number",
            "Line": "string"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"}
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "order": {"field": "ID", "type": "quantitative"},
        "detail": {"field": "Line", "type": "nominal"},
        "color": {"datum": "KTM Intercity Line"},
        "tooltip": [
          {"field": "Line", "type": "nominal", "title": "KTM Intercity Line"}
        ]
      }
    },
    {
      "name": "ktm_komuter",
      "data": {
        "url": "ktm_komuter_stations.csv",
        "format": {
          "type": "csv",
          "parse": {
            "Longitude": "number",
            "Latitude": "number",
            "ID": "number"
          }
        }
      },
      "transform": [
        {"filter": "datum.Longitude > 100"}
      ],
      "mark": {
        "type": "line",
        "strokeWidth": 3,
        "interpolate": "linear"
      },
      "encoding": {
        "longitude": {"field": "Longitude", "type": "quantitative"},
        "latitude": {"field": "Latitude", "type": "quantitative"},
        "color": {
          "field": "Line",
          "type": "nominal"
        },
        "order": {"field": "ID", "type": "quantitative"},
        "detail": {"field": "Line"},
        "tooltip": [
          {"field": "Line", "type": "nominal", "title": "KTM Komuter Line"}
        ]
      }
    }
  ]
}