{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "description": "Total passenger bar chart mapping correct fields from total_passenger.csv.",
  "width": 280,
  "height": 480,
  "data": {
    "url": "total_passenger.csv"
  },
  "mark": {
    "type": "bar",
    "tooltip": true
  },
  "encoding": {
    "x": {
      "field": "Rail type", 
      "type": "nominal", 
      "axis": {"labelAngle": 0}
    },
    "y": {
      "field": "Total Passenger(thousand)", 
      "type": "quantitative"
    },
    "color": {
      "field": "Rail type",
      "type": "nominal",
      "scale": {
        "domain": ["urban", "intercity"],
        "range": ["#9CD5FF", "#FB9B8F"]
      },
      "legend": null
    }
  }
}