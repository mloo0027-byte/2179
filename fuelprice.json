{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "title": "Fuel Price in 2024",
  "width": 500,
  "height": 400,
  "data": {
  "url": "fuelprice.csv",
  "format": {
    "parse": {
      "date": "date:'%d/%m/%Y'"
    }
  }
},
  "transform": [
    {
      "fold": ["ron95", "ron97", "diesel", "diesel_eastmsia"],
      "as": ["fuel_type", "price"]
    },
    {"filter": "datum.price > 0"}
  ],
  "mark": {
    "type": "line",
    "point": true,
    "tooltip": true,
    "interpolate": "monotone"
  },
  "encoding": {
    "x": {
      "field": "date",
      "type": "temporal",
      "timeUnit": "yearmonthdate",
      "title": "Date (2024)",
      "axis": {"format": "%b %d", "labelAngle": -45}
    },
    "y": {
      "field": "price",
      "type": "quantitative",
      "title": "Price (RM/Litre)",
      "scale": {"zero": false}
    },
    "color": {
      "field": "fuel_type",
      "type": "nominal",
      "scale": {
        "domain": ["ron95", "ron97", "diesel", "diesel_eastmsia"],
        "range": ["#FFD700", "#D51C39", "#2C5EAD", "#8A5F41 "]
      },
      "legend": {"title": "Fuel Type"}
    }
  }
}