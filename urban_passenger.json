{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "data": {"url": "rail_transportation.csv"},
  
  "width": "container",
  "height": 220,
  
  "autosize": {
    "type": "fit-x",
    "contains": "padding"
  },
  
  "layer": [{
    "params": [{
      "name": "brush",
      "select": {"type": "interval", "encodings": ["x"]}
    }],
    "mark": "bar",
    "encoding": {
      "x": {
        "field": "year",
        "type": "ordinal"
      },
      "y": {
        "aggregate": "mean",
        "field": "urban_passenger",
        "type": "quantitative"
      },
      "opacity": {
        "condition": {
          "param": "brush", "value": 1
        },
        "value": 0.7
      },
      "color": {
        "condition": {
          "param": "brush", 
          "value": "#9CD5FF"  
        },
        "value": "#9CD5FF"    
      }
    }
  }, {
    "transform": [{
      "filter": {"param": "brush"}
    }],
    "mark": "rule",
    "encoding": {
      "y": {
        "aggregate": "mean",
        "field": "urban_passenger",
        "type": "quantitative"
      },
      "color": {"value": "firebrick"},
      "size": {"value": 3}
    }
  }]
}